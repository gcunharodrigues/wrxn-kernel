{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/session-start.cjs" }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/session-end.cjs" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/synapse-engine.cjs" },
          { "type": "command", "command": "node .claude/hooks/session-history.cjs" },
          { "type": "command", "command": "node .claude/hooks/reference-detect.cjs" },
          { "type": "command", "command": "node .claude/hooks/recall-surface.cjs" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/enforce-managed-guard.cjs" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/enforce-managed-precommit.cjs" },
          { "type": "command", "command": "node .claude/hooks/enforce-push-authority.cjs" },
          { "type": "command", "command": "node .claude/hooks/enforce-tests-on-push.cjs" },
          { "type": "command", "command": "node .claude/hooks/enforce-review-marker.cjs" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/code-intel-push.cjs" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "node .claude/hooks/wiki-lint.cjs" }
        ]
      }
    ]
  }
}
